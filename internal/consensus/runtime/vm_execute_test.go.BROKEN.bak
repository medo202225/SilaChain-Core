func word32FromUint64(v uint64) []byte {
	out := make([]byte, 32)
	out[24] = byte(v >> 56)
	out[25] = byte(v >> 48)
	out[26] = byte(v >> 40)
	out[27] = byte(v >> 32)
	out[28] = byte(v >> 24)
	out[29] = byte(v >> 16)
	out[30] = byte(v >> 8)
	out[31] = byte(v)
	return out
}

func concatBytes(parts ...[]byte) []byte {
	total := 0
	for _, p := range parts {
		total += len(p)
	}

	out := make([]byte, 0, total)
	for _, p := range parts {
		out = append(out, p...)
	}
	return out
}

func TestRuntimeVMExecute_ComparisonAndBranching(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10000",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    0,
			Hash:      "0xvm-compare-genesis",
			StateRoot: "0xvm-compare-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	code := []byte{
		vmexec.OpPUSH1, 0x02,
		vmexec.OpPUSH1, 0x02,
		vmexec.OpEQ,
		vmexec.OpPUSH1, 0x0d,
		vmexec.OpJUMPI,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpRETURN,
		vmexec.OpJUMPDEST,
		vmexec.OpPUSH1, 0x31,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", code); err != nil {
		t.Fatalf("set code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
		From:     "alice",
		To:       "contract1",
		GasLimit: 50000,
	})
	if err != nil {
		t.Fatalf("vm execute: %v", err)
	}

	want := word32FromUint64(0x31)
	if !bytes.Equal(result.ReturnData, want) {
		t.Fatalf("unexpected return data: got=%v want=%v", result.ReturnData, want)
	}
}

func TestRuntimeVMExecute_LOG1_ReturnsLogs(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10000",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    0,
			Hash:      "0xvm-log-genesis",
			StateRoot: "0xvm-log-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	code := []byte{
		vmexec.OpPUSH1, 0x55,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0xaa,
		vmexec.OpLOG1,
		vmexec.OpSTOP,
	}
	if err := rt.State().SetCode("contract1", code); err != nil {
		t.Fatalf("set code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
		From:     "alice",
		To:       "contract1",
		GasLimit: 50000,
	})
	if err != nil {
		t.Fatalf("vm execute: %v", err)
	}

	if len(result.Logs) != 1 {
		t.Fatalf("unexpected log count: got=%d want=1", len(result.Logs))
	}
	wantData := word32FromUint64(0x55)
	if !bytes.Equal(result.Logs[0].Data, wantData) {
		t.Fatalf("unexpected log data: got=%v want=%v", result.Logs[0].Data, wantData)
	}
	if len(result.Logs[0].Topics) != 1 || result.Logs[0].Topics[0] != "0xaa" {
		t.Fatalf("unexpected topics: got=%v", result.Logs[0].Topics)
	}
}

func TestRuntimeVMExecute_CALL_ReturnsSuccessAndCalleeData(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10001",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    0,
			Hash:      "0xvm-call-genesis",
			StateRoot: "0xvm-call-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	calleeCode := []byte{
		vmexec.OpPUSH1, 0x4d,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract2", calleeCode); err != nil {
		t.Fatalf("set callee code: %v", err)
	}

	callerCode := []byte{
		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x02,
		vmexec.OpPUSH1, 0xff,
		vmexec.OpCALL,

		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", callerCode); err != nil {
		t.Fatalf("set caller code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
		From:     "alice",
		To:       "contract1",
		GasLimit: 50000,
	})
	if err != nil {
		t.Fatalf("vm execute: %v", err)
	}
	if !result.Success || result.Reverted {
		t.Fatalf("unexpected call status: success=%v reverted=%v", result.Success, result.Reverted)
	}

	want := word32FromUint64(0x4d)
	if !bytes.Equal(result.ReturnData, want) {
		t.Fatalf("unexpected return data: got=%v want=%v", result.ReturnData, want)
	}
}

