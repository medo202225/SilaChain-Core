		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", code); err != nil {
