		vmexec.OpPUSH1, 0x10,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", callerCode); err != nil {
		t.Fatalf("set caller code: %v", err)
	}

	_, err = rt.VMExecute(VMExecuteRequest{
		From:     "alice",
		To:       "contract1",
		GasLimit: 50000,
	})
	if !errors.Is(err, vmexec.ErrWriteProtection) {
		t.Fatalf("expected ErrWriteProtection, got=%v", err)
	}
}

func TestRuntimeVMExecute_STATICCALL_RETURNDATASIZE_RETURNDATACOPY_AfterSuccess(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10040",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    0,
			Hash:      "0xvmexec-staticcall-returndata-success-genesis",
			StateRoot: "0xvmexec-staticcall-returndata-success-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	calleeCode := []byte{
		vmexec.OpPUSH1, 0x4d,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract2", calleeCode); err != nil {
		t.Fatalf("set callee code: %v", err)
	}

	callerCode := []byte{
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x02,
		vmexec.OpPUSH1, 0xff,
		vmexec.OpSTATICCALL,

		vmexec.OpPUSH1, 0x40,
		vmexec.OpMSTORE,

		vmexec.OpRETURNDATASIZE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,

		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpRETURNDATACOPY,

		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x60,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", callerCode); err != nil {
		t.Fatalf("set caller code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
		From:     "alice",
		To:       "contract1",
		GasLimit: 50000,
	})
	if err != nil {
		t.Fatalf("vm execute: %v", err)
	}

	want := append(
		append(
			word32FromUint64(0x20),
			word32FromUint64(0x4d)...,
		),
		word32FromUint64(0x01)...,
	)
	if !bytes.Equal(result.ReturnData, want) {
		t.Fatalf("unexpected staticcall returndata success payload: got=%v want=%v", result.ReturnData, want)
	}
}

