}

func TestRuntimeVMExecute_CALL_CalleeRevertReturnsZeroAndCopiesRevertData(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10002",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    0,
			Hash:      "0xvm-call-revert-genesis",
			StateRoot: "0xvm-call-revert-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	calleeCode := []byte{
		vmexec.OpPUSH1, 0x7e,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpREVERT,
	}
	if err := rt.State().SetCode("contract2", calleeCode); err != nil {
		t.Fatalf("set callee code: %v", err)
	}

	callerCode := []byte{
		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x02,
		vmexec.OpPUSH1, 0xff,
		vmexec.OpCALL,

		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x40,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", callerCode); err != nil {
		t.Fatalf("set caller code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
		From:     "alice",
		To:       "contract1",
		GasLimit: 50000,
	})
	if err != nil {
		t.Fatalf("vm execute: %v", err)
	}

	want := concatBytes(
		word32FromUint64(0x00),
		word32FromUint64(0x7e),
	)
	if !bytes.Equal(result.ReturnData, want) {
		t.Fatalf("unexpected revert return data: got=%v want=%v", result.ReturnData, want)
	}
}

func TestRuntimeVMExecute_CALL_ContextOpcodes(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10003",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    5,
			Hash:      "0xvm-call-context-genesis",
			StateRoot: "0xvm-call-context-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	calleeCode := []byte{
		vmexec.OpADDRESS,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpCALLER,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpMSTORE,
		vmexec.OpCALLVALUE,
		vmexec.OpPUSH1, 0x40,
		vmexec.OpMSTORE,
		vmexec.OpORIGIN,
		vmexec.OpPUSH1, 0x60,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x80,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract2", calleeCode); err != nil {
		t.Fatalf("set callee code: %v", err)
	}

	callerCode := []byte{
		vmexec.OpPUSH1, 0x80,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x08,
		vmexec.OpPUSH1, 0x02,
		vmexec.OpPUSH1, 0xff,
		vmexec.OpCALL,

		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x80,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", callerCode); err != nil {
		t.Fatalf("set caller code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
		From:     "alice",
		To:       "contract1",
		Value:    0x09,
		GasLimit: 50000,
	})
	if err != nil {
		t.Fatalf("vm execute: %v", err)
	}

	want := concatBytes(
		word32FromUint64(0x02),
		word32FromUint64(0x01),
		word32FromUint64(0x08),
		word32FromUint64(0x00),
	)
	if !bytes.Equal(result.ReturnData, want) {
		t.Fatalf("unexpected context return data: got=%v want=%v", result.ReturnData, want)
	}
}

func TestRuntimeVMExecute_CALL_CalleeStorageIsolation(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10004",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    0,
			Hash:      "0xvm-call-storage-genesis",
			StateRoot: "0xvm-call-storage-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	calleeCode := []byte{
		vmexec.OpPUSH1, 0x55,
		vmexec.OpPUSH1, 0x01,
		vmexec.OpSSTORE,
		vmexec.OpPUSH1, 0x01,
		vmexec.OpSLOAD,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract2", calleeCode); err != nil {
		t.Fatalf("set callee code: %v", err)
	}

	callerCode := []byte{
		vmexec.OpPUSH1, 0x99,
		vmexec.OpPUSH1, 0x01,
		vmexec.OpSSTORE,

		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x02,
		vmexec.OpPUSH1, 0xff,
		vmexec.OpCALL,

		vmexec.OpPUSH1, 0x01,
		vmexec.OpSLOAD,
		vmexec.OpPUSH1, 0x40,
		vmexec.OpMSTORE,

		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x40,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", callerCode); err != nil {
		t.Fatalf("set caller code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
		From:     "alice",
		To:       "contract1",
		GasLimit: 50000,
	})
	if err != nil {
		t.Fatalf("vm execute: %v", err)
	}

	want := concatBytes(
		word32FromUint64(0x55),
		word32FromUint64(0x99),
	)
	if !bytes.Equal(result.ReturnData, want) {
		t.Fatalf("unexpected storage isolation return data: got=%v want=%v", result.ReturnData, want)
	}
}

