func TestRuntimeVMExecute_DELEGATECALL_FailureCanBePropagatedByCaller(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10036",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    0,
			Hash:      "0xvmexec-delegatecall-propagate-genesis",
			StateRoot: "0xvmexec-delegatecall-propagate-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	libraryCode := []byte{
		vmexec.OpPUSH1, 0x7e,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x08,
		vmexec.OpREVERT,
	}
	if err := rt.State().SetCode("contract2", libraryCode); err != nil {
		t.Fatalf("set library code: %v", err)
	}

	callerCode := []byte{
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x02,
		vmexec.OpPUSH1, 0xff,
		vmexec.OpDELEGATECALL,

		vmexec.OpISZERO,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpJUMPI,

		vmexec.OpPUSH1, 0x01,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x08,
		vmexec.OpRETURN,

		vmexec.OpJUMPDEST,
		vmexec.OpPUSH1, 0x7e,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x08,
		vmexec.OpREVERT,
	}
	for i, op := range callerCode {
		if op == vmexec.OpJUMPDEST {
			callerCode[15] = byte(i)
			break
		}
	}

	if err := rt.State().SetCode("contract1", callerCode); err != nil {
		t.Fatalf("set caller code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
		From:     "alice",
		To:       "contract1",
		GasLimit: 50000,
	})
	if err != nil {
		t.Fatalf("vm execute: %v", err)
	}

	if result.Success || !result.Reverted {
		t.Fatalf("caller should propagate delegatecall failure, got success=%v reverted=%v", result.Success, result.Reverted)
	}

	want := []byte{0, 0, 0, 0, 0, 0, 0, 0}
	if !bytes.Equal(result.ReturnData, want) {
		t.Fatalf("unexpected propagated delegatecall data: got=%v want=%v", result.ReturnData, want)
	}
}

func TestRuntimeVMExecute_STATICCALL_AllowsReadOnlyExecution(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10037",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    0,
			Hash:      "0xvmexec-staticcall-read-genesis",
			StateRoot: "0xvmexec-staticcall-read-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	if err := rt.State().SetStorage("contract2", "0x1", "0x44"); err != nil {
		t.Fatalf("seed storage: %v", err)
	}

	calleeCode := []byte{
		vmexec.OpPUSH1, 0x01,
		vmexec.OpSLOAD,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,

		vmexec.OpCALLVALUE,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpMSTORE,

		vmexec.OpCALLER,
		vmexec.OpPUSH1, 0x40,
		vmexec.OpMSTORE,

		vmexec.OpADDRESS,
		vmexec.OpPUSH1, 0x60,
		vmexec.OpMSTORE,

		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x80,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract2", calleeCode); err != nil {
		t.Fatalf("set callee code: %v", err)
	}

	callerCode := []byte{
		vmexec.OpPUSH1, 0x80,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x02,
		vmexec.OpPUSH1, 0xff,
		vmexec.OpSTATICCALL,

		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x80,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", callerCode); err != nil {
		t.Fatalf("set caller code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
		From:     "contract9",
		To:       "contract1",
		Value:    0x07,
		GasLimit: 50000,
	})
	if err != nil {
		t.Fatalf("vm execute: %v", err)
	}

	want := append(
		append(
			append(
				word32FromUint64(0x44),
				word32FromUint64(0x00)...,
			),
			word32FromUint64(0x01)...,
		),
		word32FromUint64(0x02)...,
	)
	if !bytes.Equal(result.ReturnData, want) {
		t.Fatalf("unexpected staticcall read payload: got=%v want=%v", result.ReturnData, want)
	}
}

