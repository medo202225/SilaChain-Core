			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	code := []byte{
		vmexec.OpPUSH1, 0x06,
		vmexec.OpPUSH1, 0x08,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpCODECOPY,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x06,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", code); err != nil {
		t.Fatalf("set code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
