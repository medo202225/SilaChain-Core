func TestRuntimeVMExecute_CALL_DepthLimitReturnsZeroAndZerosRetArea(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10007",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    0,
			Hash:      "0xvm-call-depth-genesis",
			StateRoot: "0xvm-call-depth-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	leafCode := []byte{
		vmexec.OpPUSH1, 0xee,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract6", leafCode); err != nil {
		t.Fatalf("set leaf code: %v", err)
	}

	reentrantTemplate := func(target byte) []byte {
		return []byte{
			vmexec.OpPUSH1, 0xaa,
			vmexec.OpPUSH1, 0x20,
			vmexec.OpMSTORE,

			vmexec.OpPUSH1, 0x20,
			vmexec.OpPUSH1, 0x20,
			vmexec.OpPUSH1, 0x00,
			vmexec.OpPUSH1, 0x00,
			vmexec.OpPUSH1, 0x00,
			vmexec.OpPUSH1, target,
			vmexec.OpPUSH1, 0xff,
			vmexec.OpCALL,

			vmexec.OpPUSH1, 0x20,
			vmexec.OpMSTORE,

			vmexec.OpPUSH1, 0x00,
			vmexec.OpPUSH1, 0x40,
			vmexec.OpRETURN,
		}
	}

	if err := rt.State().SetCode("contract2", reentrantTemplate(0x03)); err != nil {
		t.Fatalf("set reentrant code for contract2: %v", err)
	}
	if err := rt.State().SetCode("contract3", reentrantTemplate(0x04)); err != nil {
		t.Fatalf("set reentrant code for contract3: %v", err)
	}
	if err := rt.State().SetCode("contract4", reentrantTemplate(0x05)); err != nil {
		t.Fatalf("set reentrant code for contract4: %v", err)
	}
	if err := rt.State().SetCode("contract5", reentrantTemplate(0x06)); err != nil {
		t.Fatalf("set reentrant code for contract5: %v", err)
	}

	entryCode := []byte{
		vmexec.OpPUSH1, 0x10,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpMSTORE,

		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x02,
		vmexec.OpPUSH1, 0xff,
		vmexec.OpCALL,

		vmexec.OpPUSH1, 0x20,
		vmexec.OpMSTORE,

		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x40,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", entryCode); err != nil {
		t.Fatalf("set entry code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
		From:     "alice",
		To:       "contract1",
		GasLimit: 50000,
	})
	if err != nil {
		t.Fatalf("vm execute: %v", err)
	}

	want := concatBytes(
		word32FromUint64(0x00),
		word32FromUint64(0x01),
	)
	if !bytes.Equal(result.ReturnData, want) {
		t.Fatalf("unexpected depth-limit return data: got=%v want=%v", result.ReturnData, want)
	}
}

func TestIntrospectionServer_ExposesVMExecuteEndpoint_WithComparisons(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10000",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    0,
			Hash:      "0xvm-http-compare-genesis",
			StateRoot: "0xvm-http-compare-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	code := []byte{
		vmexec.OpPUSH1, 0x04,
		vmexec.OpPUSH1, 0x04,
		vmexec.OpEQ,
		vmexec.OpPUSH1, 0x0d,
		vmexec.OpJUMPI,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpRETURN,
		vmexec.OpJUMPDEST,
		vmexec.OpPUSH1, 0x44,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", code); err != nil {
		t.Fatalf("set code: %v", err)
	}

	server, err := NewIntrospectionServer(rt)
	if err != nil {
		t.Fatalf("new introspection server: %v", err)
	}
	ts := httptest.NewServer(server.Handler())
	defer ts.Close()

	payload := map[string]any{
		"from":     "alice",
		"to":       "contract1",
		"gasLimit": 50000,
	}

	body, _ := json.Marshal(payload)
	resp, err := http.Post(ts.URL+"/vm/execute", "application/json", bytes.NewReader(body))
	if err != nil {
		t.Fatalf("post vm execute: %v", err)
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		t.Fatalf("unexpected status code: got=%d want=%d", resp.StatusCode, http.StatusOK)
	}

	var out struct {
		Result struct {
			ReturnData []byte `json:"returnData"`
		} `json:"result"`
		Error string `json:"error"`
	}
	if err := json.NewDecoder(resp.Body).Decode(&out); err != nil {
		t.Fatalf("decode response: %v", err)
	}
	if out.Error != "" {
		t.Fatalf("unexpected response error: %s", out.Error)
	}

	want := word32FromUint64(0x44)
	if !bytes.Equal(out.Result.ReturnData, want) {
		t.Fatalf("unexpected return data: got=%v want=%v", out.Result.ReturnData, want)
	}
}

func TestIntrospectionServer_ExposesVMExecuteEndpoint_WithLogs(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10000",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    0,
			Hash:      "0xvm-http-log-genesis",
			StateRoot: "0xvm-http-log-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	code := []byte{
		vmexec.OpPUSH1, 0x66,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0xbb,
		vmexec.OpLOG1,
		vmexec.OpSTOP,
	}
	if err := rt.State().SetCode("contract1", code); err != nil {
		t.Fatalf("set code: %v", err)
	}

	server, err := NewIntrospectionServer(rt)
	if err != nil {
		t.Fatalf("new introspection server: %v", err)
	}
	ts := httptest.NewServer(server.Handler())
	defer ts.Close()

	payload := map[string]any{
		"from":     "alice",
		"to":       "contract1",
		"gasLimit": 50000,
	}

	body, _ := json.Marshal(payload)
	resp, err := http.Post(ts.URL+"/vm/execute", "application/json", bytes.NewReader(body))
	if err != nil {
		t.Fatalf("post vm execute: %v", err)
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		t.Fatalf("unexpected status code: got=%d want=%d", resp.StatusCode, http.StatusOK)
	}

	var out struct {
		Result struct {
			Logs []struct {
				Data []byte `json:"data"`
			} `json:"logs"`
		} `json:"result"`
		Error string `json:"error"`
	}
	if err := json.NewDecoder(resp.Body).Decode(&out); err != nil {
		t.Fatalf("decode response: %v", err)
	}
	if out.Error != "" {
		t.Fatalf("unexpected response error: %s", out.Error)
	}

	if len(out.Result.Logs) != 1 {
		t.Fatalf("unexpected log count: got=%d want=1", len(out.Result.Logs))
	}
	wantData := word32FromUint64(0x66)
	if !bytes.Equal(out.Result.Logs[0].Data, wantData) {
		t.Fatalf("unexpected http log data: got=%v want=%v", out.Result.Logs[0].Data, wantData)
	}
}
func TestRuntimeVMExecute_RETURNDATASIZE_RETURNDATACOPY_AfterSuccessfulCALL(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10008",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    0,
			Hash:      "0xvm-returndata-success-genesis",
			StateRoot: "0xvm-returndata-success-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	calleeCode := []byte{
		vmexec.OpPUSH1, 0x4d,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract2", calleeCode); err != nil {
		t.Fatalf("set callee code: %v", err)
	}

	callerCode := []byte{
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x02,
		vmexec.OpPUSH1, 0xff,
		vmexec.OpCALL,

		vmexec.OpRETURNDATASIZE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,

		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpRETURNDATACOPY,

		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x40,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", callerCode); err != nil {
		t.Fatalf("set caller code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
		From:     "alice",
		To:       "contract1",
		GasLimit: 50000,
	})
	if err != nil {
		t.Fatalf("vm execute: %v", err)
	}

	want := concatBytes(
		word32FromUint64(0x20),
		word32FromUint64(0x4d),
	)
	if !bytes.Equal(result.ReturnData, want) {
		t.Fatalf("unexpected returndata success payload: got=%v want=%v", result.ReturnData, want)
	}
}

