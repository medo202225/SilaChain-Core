	if err := rt.State().SetCode("contract2", libraryCode); err != nil {
		t.Fatalf("set library code: %v", err)
	}

	callerCode := []byte{
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpMSTORE,

		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x02,
		vmexec.OpPUSH1, 0xff,
		vmexec.OpDELEGATECALL,

		vmexec.OpPUSH1, 0x40,
		vmexec.OpMSTORE,

		vmexec.OpRETURNDATASIZE,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,

		vmexec.OpPUSH1, 0x20,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpRETURNDATACOPY,

		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x60,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", callerCode); err != nil {
		t.Fatalf("set caller code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
		From:     "alice",
		To:       "contract1",
		GasLimit: 50000,
	})
	if err != nil {
		t.Fatalf("vm execute: %v", err)
	}

	want := append(
		append(
			word32FromUint64(0x20),
			word32FromUint64(0x7e)...,
		),
		word32FromUint64(0x00)...,
	)
	if !bytes.Equal(result.ReturnData, want) {
		t.Fatalf("unexpected delegatecall revert/returndata payload: got=%v want=%v", result.ReturnData, want)
	}
}

