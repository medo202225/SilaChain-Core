func TestRuntimeVMExecute_DELEGATECALL_UsesCallerStorageAndOriginalContext(t *testing.T) {
	rt, err := New(Config{
		ListenAddress: "127.0.0.1:10028",
		GasLimit:      30000000,
		GenesisHead: blockassembly.Head{
			Number:    0,
			Hash:      "0xvmexec-delegatecall-genesis",
			StateRoot: "0xvmexec-delegatecall-state",
			BaseFee:   1,
		},
	})
	if err != nil {
		t.Fatalf("new runtime: %v", err)
	}

	libraryCode := []byte{
		vmexec.OpCALLER,
		vmexec.OpPUSH1, 0x01,
		vmexec.OpSSTORE,

		vmexec.OpCALLVALUE,
		vmexec.OpPUSH1, 0x02,
		vmexec.OpSSTORE,

		vmexec.OpADDRESS,
		vmexec.OpPUSH1, 0x03,
		vmexec.OpSSTORE,

		vmexec.OpPUSH1, 0x01,
		vmexec.OpSLOAD,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpMSTORE,

		vmexec.OpPUSH1, 0x02,
		vmexec.OpSLOAD,
		vmexec.OpPUSH1, 0x20,
		vmexec.OpMSTORE,

		vmexec.OpPUSH1, 0x03,
		vmexec.OpSLOAD,
		vmexec.OpPUSH1, 0x40,
		vmexec.OpMSTORE,

		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x60,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract2", libraryCode); err != nil {
		t.Fatalf("set library code: %v", err)
	}

	callerCode := []byte{
		vmexec.OpPUSH1, 0x60,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x02,
		vmexec.OpPUSH1, 0xff,
		vmexec.OpDELEGATECALL,

		vmexec.OpPUSH1, 0x00,
		vmexec.OpPUSH1, 0x60,
		vmexec.OpRETURN,
	}
	if err := rt.State().SetCode("contract1", callerCode); err != nil {
		t.Fatalf("set caller code: %v", err)
	}

	result, err := rt.VMExecute(VMExecuteRequest{
		From:     "contract9",
		To:       "contract1",
		Value:    0x07,
		GasLimit: 50000,
	})
	if err != nil {
		t.Fatalf("vm execute: %v", err)
	}

	want := append(
		append(
			word32FromUint64(0x09),
			word32FromUint64(0x07)...,
		),
		word32FromUint64(0x02)...,
	)
	if !bytes.Equal(result.ReturnData, want) {
		t.Fatalf("unexpected delegatecall return data: got=%v want=%v", result.ReturnData, want)
	}
}

