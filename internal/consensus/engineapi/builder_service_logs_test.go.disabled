package engineapi

import (
	"testing"

	"silachain/internal/consensus/blockassembly"
	"silachain/internal/consensus/txpool"
)

func TestBuilderService_CanonicalLogsAndReceipts_FromCanonicalCache(t *testing.T) {
	blockHash := "sila-block-1-0xgenesis-2"

	txs := []txpool.Tx{
		{
			Hash:                 "tx-log-1",
			From:                 "alice",
			Nonce:                0,
			GasLimit:             21000,
			MaxFeePerGas:         20,
			MaxPriorityFeePerGas: 2,
			Timestamp:            1,
		},
		{
			Hash:                 "tx-log-2",
			From:                 "bob",
			Nonce:                0,
			GasLimit:             21000,
			MaxFeePerGas:         30,
			MaxPriorityFeePerGas: 3,
			Timestamp:            2,
		},
	}

	logsByTx, logs := makeSyntheticCanonicalLogs(blockHash, 1, txs)
	receipts := makeCanonicalReceipts(blockHash, 1, txs, 42000, logsByTx)

	svc := &BuilderService{
		cache: map[string]cachedPayload{
			"payload-1": {
				id: "payload-1",
				built: blockassembly.Result{
					BlockNumber:     1,
					ParentNumber:    0,
					ParentHash:      "0xgenesis",
					ParentStateRoot: "0xstate0",
					BaseFee:         1,
					GasLimit:        30000000,
					Selection: blockassembly.TransactionSelection{
						Transactions: txs,
						GasUsed:      42000,
						TotalTipFees: 0,
					},
				},
				receipts: receipts,
				logsByTx: logsByTx,
				logs:     logs,
				metadata: PayloadMetadata{
					PayloadID:             "payload-1",
					BlockNumber:           1,
					BlockHash:             blockHash,
					ParentHash:            "0xgenesis",
					ParentStateRoot:       "0xstate0",
					BaseFee:               1,
					GasLimit:              30000000,
					GasUsed:               42000,
					TxCount:               2,
					BuildSequence:         1,
					SubmittedToNewPayload: true,
					Canonical:             true,
					LatestStatus:          "CANONICAL",
					Transactions:          txs,
				},
			},
		},
		blockToPayload: map[string]string{
			blockHash: "payload-1",
		},
	}

	receipt, ok := svc.CanonicalReceiptByTxHash("tx-log-1")
	if !ok {
		t.Fatal("expected canonical receipt by tx hash")
	}
	if receipt.BlockHash != blockHash {
		t.Fatalf("unexpected receipt block hash: got=%s want=%s", receipt.BlockHash, blockHash)
	}
	if receipt.GasUsed != 21000 {
		t.Fatalf("unexpected receipt gas used: got=%d want=21000", receipt.GasUsed)
	}
	if len(receipt.Logs) != 1 {
		t.Fatalf("unexpected receipt log count: got=%d want=1", len(receipt.Logs))
	}
	if receipt.Logs[0].Address != "alice" {
		t.Fatalf("unexpected receipt log address: got=%s want=alice", receipt.Logs[0].Address)
	}

	receiptsByNumber, ok := svc.CanonicalReceiptsByBlockNumber(1)
	if !ok {
		t.Fatal("expected canonical receipts by block number")
	}
	if len(receiptsByNumber) != 2 {
		t.Fatalf("unexpected receipts count: got=%d want=2", len(receiptsByNumber))
	}
	if len(receiptsByNumber[0].Logs) != 1 {
		t.Fatalf("unexpected first block receipt logs count: got=%d want=1", len(receiptsByNumber[0].Logs))
	}

	txLogs, ok := svc.CanonicalLogsByTxHash("tx-log-1")
	if !ok {
		t.Fatal("expected canonical logs by tx hash")
	}
	if len(txLogs) != 1 {
		t.Fatalf("unexpected tx logs count: got=%d want=1", len(txLogs))
	}
	if txLogs[0].Address != "alice" {
		t.Fatalf("unexpected tx log address: got=%s want=alice", txLogs[0].Address)
	}
	if len(txLogs[0].Topics) != 1 || txLogs[0].Topics[0] != "0xsila_tx_included" {
		t.Fatalf("unexpected tx log topics: got=%v", txLogs[0].Topics)
	}
	if txLogs[0].BlockNumber != 1 {
		t.Fatalf("unexpected tx log block number: got=%d want=1", txLogs[0].BlockNumber)
	}

	blockLogs, ok := svc.CanonicalLogsByBlockHash(blockHash)
	if !ok {
		t.Fatal("expected canonical logs by block hash")
	}
	if len(blockLogs) != 2 {
		t.Fatalf("unexpected block logs count: got=%d want=2", len(blockLogs))
	}
	if blockLogs[0].LogIndex != 0 {
		t.Fatalf("unexpected first log index: got=%d want=0", blockLogs[0].LogIndex)
	}
	if blockLogs[1].LogIndex != 1 {
		t.Fatalf("unexpected second log index: got=%d want=1", blockLogs[1].LogIndex)
	}

	blockLogsByNumber, ok := svc.CanonicalLogsByBlockNumber(1)
	if !ok {
		t.Fatal("expected canonical logs by block number")
	}
	if len(blockLogsByNumber) != 2 {
		t.Fatalf("unexpected block logs by number count: got=%d want=2", len(blockLogsByNumber))
	}
}
